# --- Clé d'encryption n8n (à personnaliser, longue et secrète) ---
N8N_ENCRYPTION_KEY=une_cle_longue_aleatoire_a_generer
# --- Telegram ---
TELEGRAM_BOT_TOKEN=ton_token_bot_telegram_ici
# --- Groq (injectée automatiquement dans le credential "Groq_API" du node HTTP Request) ---
# Mets ta vraie clé ici (sans "Bearer "), puis redémarre : docker compose down && docker compose up -d
GROQ_API_KEY=ta_cle_api_groq_ici
# --- Google Sheets OAuth2 (pré-remplit Client ID / Client Secret dans le credential n8n) ---
GOOGLE_OAUTH_CLIENT_ID=ton_client_id_google.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=ton_client_secret_google